# Cookie sessionKey do claude.ai
# Como obter: DevTools → Application → Cookies → claude.ai → sessionKey
CLAUDE_SESSION_KEY=sk-ant-sid02-...

# ID da sua organização no claude.ai
# Como obter: DevTools → Network → qualquer request para /api/organizations/{ID}/...
# Ou: cookie lastActiveOrg no browser
CLAUDE_ORG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Token Bearer que o Pico vai usar para autenticar na API
# Pode ser qualquer string segura, ex.: openssl rand -hex 32
API_BEARER_TOKEN=troque-por-um-token-seguro

# Timeout em segundos para chamadas ao claude.ai (opcional, default: 10)
POLL_TIMEOUT=10
