# Cookie sessionKey do claude.ai
# Como obter: DevTools → Application → Cookies → claude.ai → sessionKey
CLAUDE_SESSION_KEY=sk-ant-sid02-...

# ID da sua organização no claude.ai
# Como obter: DevTools → Network → qualquer request para /api/organizations/{ID}/...
# Ou: cookie lastActiveOrg no browser
CLAUDE_ORG_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Token Bearer que o Pico vai usar para autenticar na API
# Pode ser qualquer string segura, ex.: openssl rand -hex 32
API_BEARER_TOKEN=troque-por-um-token-seguro

# Timeout em segundos para chamadas ao claude.ai (opcional, default: 10)
POLL_TIMEOUT=10

# Cookies extras do browser (opcional) — use quando receber 403 do Cloudflare
# Como obter: DevTools → Application → Cookies → claude.ai
# Inclua: cf_clearance, __cf_logged_in, __cf_bm e CF_VERIFIED_DEVICE_* separados por "; "
# Exemplo: EXTRA_COOKIES=cf_clearance=Girk9v...; __cf_logged_in=1; __cf_bm=SG4Q...; CF_VERIFIED_DEVICE_<hash>=<timestamp>
EXTRA_COOKIES=

# ── LibreLinkUp (opcional) ────────────────────────────────────────────────────
# Email e senha do app FreeStyle LibreLink (os mesmos que você usa no celular)
# Deixe vazio para desativar o endpoint /glucose
LLU_EMAIL=
LLU_PASSWORD=
# ID do paciente — obtenha fazendo login com a conta principal em /llu/auth/login
# campo: data.user.id
LLU_PATIENT_ID=
